rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isActive() {
      return getUserData().status == 'ACTIVE' && getUserData().isApproved == true;
    }
    
    function isAdmin() {
      return getUserData().role in ['ADMIN', 'SUPER_ADMIN'];
    }

    // User collection rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
    }

    // Inventory collection rules
    match /inventory/{itemId} {
      allow read: if isSignedIn() && isActive();
      allow write: if isAdmin();
    }

    // Requests collection rules
    match /requests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isSignedIn() && isActive() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Transactions collection rules
    match /transactions/{transId} {
      allow read: if isAdmin();
      allow write: if false; // Only written via Admin SDK / Cloud Functions
    }
  }
}
